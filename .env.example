# Default: run the LLM locally with Ollama, no OpenAI key required.
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Optional: use OpenAI or another OpenAI-compatible provider instead.
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Optional: use Tavily for more reliable web search.
# If not set, the agent falls back to DuckDuckGo HTML search.
# TAVILY_API_KEY=your_tavily_api_key_here

# Optional: OpenAI-compatible endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1
